# ==============================================
# Stack Chat API - ENVIRONMENT VARIABLES
# ==============================================

# Application Configuration
APP_PORT=3000
NODE_ENV=development

# MongoDB Database Configuration
# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/stack-chat?retryWrites=true&w=majority
MONGODB_URI=

# JWT Configuration
JWT_ACCESS_SECRETKEY=your-super-secret-access-key-change-this-in-production-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRETKEY=your-super-secret-refresh-key-change-this-in-production-at-least-32-chars
JWT_REFRESH_EXPIRES=7d

# Default Reset Password
RESET_PASSWORD=123456

# Node Environment
NODE_ENV=development

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=muoivo.051064@gmail.com
MAIL_PASS=rcoe dkio gwyp cwbl
MAIL_FROM=Stack Chat

GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxx
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ==============================================
# OPTIONAL CONFIGURATIONS
# ==============================================

KEEP_ALIVE_ENABLED=true
KEEP_ALIVE_INTERVAL=30

# File Storage Configuration
STORAGE_LOCATED=LOCAL
UPLOAD_PATH=uploads/
AVATAR_PATH=uploads/avatars/
DOCUMENT_PATH=uploads/documents/

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Logging Configuration
LOG_LEVEL=info

# Keep-Alive Service Configuration
KEEP_ALIVE_ENABLED=true
KEEP_ALIVE_INTERVAL=30

# Timezone
TZ=Asia/Ho_Chi_Minh

# Security
BCRYPT_SALT_ROUNDS=10
SESSION_SECRET=your-session-secret-key

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_CORS=true
ENABLE_RATE_LIMITING=false
ENABLE_LOGGING=true